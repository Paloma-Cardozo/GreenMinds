        {
          "name": "5. Login - Rate Limit Exceeded (429)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 429) {\r",
                  "  pm.test(\"Rate limit triggered correctly - Status 429\", function () {\r",
                  "    pm.response.to.have.status(429);\r",
                  "  });\r",
                  "\r",
                  "  pm.test(\"Rate limit error message is clear\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.error).to.include(\"Too many login attempts\");\r",
                  "  });\r",
                  "} else {\r",
                  "  pm.test(\"Still within rate limit - Status 401 as expected\", function () {\r",
                  "    pm.response.to.have.status(401);\r",
                  "  });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"ratelimit_test@example.com\",\r\n  \"password\": \"WrongPassword9999\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
