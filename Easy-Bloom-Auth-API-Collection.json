        {
          "name": "4. Login - Wrong Password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Wrong password rejected - Status 401\", function () {\r",
                  "  pm.response.to.have.status(401);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Error message is generic (doesn't reveal if email exists)\", function () {\r",
                  "  var jsonData = pm.response.json();\r",
                  "  pm.expect(jsonData).to.have.property(\"error\");\r",
                  "  pm.expect(jsonData.error).to.eql(\"Email or password incorrect\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
