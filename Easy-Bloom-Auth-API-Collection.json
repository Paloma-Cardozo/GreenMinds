  "item": [
    {
      "name": "Auth - Error Cases",
      "item": [
        {
          "name": "1. Signup - Duplicate Email (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Duplicate email rejected - Status 400\", function () {\r",
                  "  pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Error message mentions email\", function () {\r",
                  "  var jsonData = pm.response.json();\r",
                  "  pm.expect(jsonData).to.have.property(\"error\");\r",
                  "  pm.expect(jsonData.error.toLowerCase()).to.include(\"email\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"duplicate_email_test\",\r\n  \"email\": \"{{user_email}}\",\r\n  \"password\": \"TestPassword1234\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/signup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          },
          "response": []
        },
