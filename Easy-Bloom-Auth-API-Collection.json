          "name": "1. GET /plants/options",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Each plant has required fields\", function () {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.length > 0) {",
                  "    var plant = jsonData[0];",
                  "    pm.expect(plant).to.have.property('id');",
                  "    pm.expect(plant).to.have.property('pid');",
                  "    pm.expect(plant).to.have.property('alias');",
                  "    pm.expect(plant).to.have.property('img_url');",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/plants/options",
              "host": ["{{base_url}}"],
              "path": ["plants", "options"]
            }
          },
          "response": []
        },
        {
          "name": "2. GET /plants/search - Valid Query",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has count and results\", function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('count');",
                  "  pm.expect(jsonData).to.have.property('results');",
                  "  pm.expect(jsonData.results).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Results filtered to query term\", function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.count).to.be.above(0);",
                  "  pm.expect(jsonData.results.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"Each result has pid and alias\", function () {",
                  "  var results = pm.response.json().results;",
                  "  if (results.length > 0) {",
                  "    pm.expect(results[0]).to.have.property('pid');",
                  "    pm.expect(results[0]).to.have.property('alias');",
                  "  }",
                  "});",
                  "",
                  "// Save first pid for use in care and favorites requests",
                  "var results = pm.response.json().results;",
                  "if (results && results.length > 0) {",
                  "  pm.environment.set('plant_pid', results[0].pid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
