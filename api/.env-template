# This is the port the API will be available at

PORT=3001

# Set this in Render's environment variables when deployed, to the public API URL (e.g. https://greenminds-api.onrender.com/api)

# API_URL=

# -- Database configuration --

# If you set up and use a database, you'll need to use the corresponding configuration

# below as a starting point. Uncomment the section you need and customise with your

# own correct values.

#

# The default enabled configuration is for SQLite.

# General configuration

DB_HOST=localhost
DB_PORT=5432
DB_USE_SSL=false # The database you use for local development most likely doesn't use SSL (encryption) but when you deploy it, you should set this to true on that environment.

# PostgreSQL configuration - comment out/uncomment as needed

DB_CLIENT=pg
DB_USER=greenminds_user
DB_PASSWORD=your_password
DB_DATABASE_NAME=greenminds

# SQLite configuration - comment out/uncomment as needed

#DB_CLIENT=sqlite3
#DB_SQLITE_FILENAME="./src/database.sqlite3"

# MySQL configuration - comment out/uncomment as needed

#DB_CLIENT=mysql2
#DB_USER=root
#DB_PASSWORD=root_password
#DB_DATABASE_NAME=database_name

# -- Database configuration end --

# Register at https://open.plantbook.io and generate credentials under API keys

PLANTBOOK_CLIENT_ID=your_plant_book_client_id
PLANTBOOK_CLIENT_SECRET=your_plant_book_secret
JWT_SECRET=your_jwt_secret
